{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "supabase-mcp-server@latest"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": ""
      }
    },
    "skills": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/claude-code-skills-mcp@latest"]
    }
  }
}
